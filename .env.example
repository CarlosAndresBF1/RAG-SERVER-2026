# .env.example — Copy to .env and fill in values
# cp .env.example .env

# ── Database ──────────────────────────────
POSTGRES_DB=odyssey_rag
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=                  # REQUIRED: set a strong password
POSTGRES_PORT=5433          # 5432 reserved by Odyssey

# ── RAG API ───────────────────────────────
RAG_API_PORT=8089           # 8080 reserved by Odyssey
LOG_LEVEL=info
ENVIRONMENT=development             # development | staging | production

# ── Embeddings ────────────────────────────
EMBEDDING_PROVIDER=nomic-local      # nomic-local | openai | cohere
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIMENSION=768

# ── LLM Provider ─────────────────────────
LLM_PROVIDER=openai                 # openai | anthropic | gemini
OPENAI_API_KEY=                     # Required if LLM_PROVIDER=openai
ANTHROPIC_API_KEY=                  # Required if LLM_PROVIDER=anthropic
GOOGLE_API_KEY=                     # Required if LLM_PROVIDER=gemini

# ── Reranker ──────────────────────────────
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Search ────────────────────────────────
DEFAULT_TOP_K=8

# ── Ingestion ─────────────────────────────
CHUNK_SIZE=512                      # tokens per chunk
CHUNK_OVERLAP=64                    # token overlap between chunks

# ── MCP Server ────────────────────────────
MCP_TRANSPORT=http                  # http | stdio
MCP_PORT=3010               # 3000 reserved by Odyssey
MCP_API_KEY=                        # API key for HTTP mode auth
